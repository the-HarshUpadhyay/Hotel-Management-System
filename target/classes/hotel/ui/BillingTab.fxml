<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hotel.ui.BillingTabController">
    <VBox spacing="18" styleClass="tab-content">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32" />
        </padding>
        <Label text="Billing &amp; Checkout Management" styleClass="section-title" />
        <Separator opacity="0.3" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Select Active Booking: " styleClass="form-label" />
            <ComboBox fx:id="bookingComboBox" prefWidth="350" styleClass="input-field" promptText="Choose a booking to check out" />
            <Button text="💳 Check Out &amp; Bill" styleClass="btn, btn-primary" onAction="#handleCheckOutAction" />
            <Button text="↻ Refresh" styleClass="btn, btn-info" onAction="#loadBookings" />
        </HBox>

        <Separator opacity="0.3" />
        <Label text="Recent Invoices" styleClass="section-title" />

        <TableView fx:id="billsTable" prefHeight="350" styleClass="data-table">
            <placeholder>
                <Label text="No invoices generated."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colBillId" text="Invoice ID" />
                <TableColumn fx:id="colBookingRef" text="Booking Ref" />
                <TableColumn fx:id="colAmount" text="Amount" />
                <TableColumn fx:id="colDate" text="Date Generated" />
                <TableColumn fx:id="colPaid" text="Status" />
                <TableColumn fx:id="colAction" text="Action" />
            </columns>
            <columnResizePolicy>
                 <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</ScrollPane>
